# ED Colonisation Tracker — configuration example
# Copy this file to .env and fill in any values you want to override.

# Inara login cookie — greatly improves station lookup reliability.
# How to get it:
#   1. Log into https://inara.cz in your browser
#   2. Open DevTools (F12) → Application → Cookies → https://inara.cz
#   3. Find the cookie named  __Host-InaraUser
#   4. Paste its Value below (just the value, not the name)
INARA_USER_COOKIE=

# Override the Elite Dangerous journal directory if it's not in the default location
#ED_JOURNAL_DIR=C:\Users\you\Saved Games\Frontier Developments\Elite Dangerous

# HTTP port for the web UI (default: 3000)
#PORT=3000

# Log level: debug | info | warn | error (default: info)
#LOG_LEVEL=info
